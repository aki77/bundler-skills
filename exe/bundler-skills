#!/usr/bin/env ruby
# frozen_string_literal: true

# require "bundler" so a bare invocation (not via `bundle exec`) still has
# Bundler loaded — the CLI resolves the project via Bundler.root and reads
# dependency specs from Bundler.load. Without this, `bundler-skills` run
# directly from PATH crashes with an uninitialized-constant Bundler error.
require "bundler"
require "bundler_skills"
require "bundler_skills/cli"

exit BundlerSkills::CLI.new.run(ARGV)
